# __SHARED__
DIND_HOME_PATH=/.vibeboyrunner
DIND_WORKDIR_PATH=/workdir
DIND_WORKSPACES_PATH=/workdir/workspaces
DIND_SERVICES_PATH=/vibeboyrunner/services

DIND_CONTAINER_NAME=vbr-dind
AGENT_PROVIDERS=cursor
MANAGER_PORT=18080
APP_COMPOSE_SERVICE_NAME=app
MANAGER_AGENT_MODEL="GPT-5.3 Codex Low Fast"
GIT_USER_NAME="VibeBoyRunner Father Agent"
GIT_USER_EMAIL="father@vibeboy.run"
ONBOARDING_APP_REPO=vibeboyrunner/onboarding

# Host<->dind 1:1 port range mapping (500 ports by default).
HOST_PORT_RANGE_START=20000
HOST_PORT_RANGE_END=20499
DIND_PORT_RANGE_START=20000
DIND_PORT_RANGE_END=20499

# __DEV__
# Host bind-mount paths (dev uses bind mounts, prod uses named volumes).
HOST_HOME_PATH=./dev/runtime/.vibeboyrunner
HOST_WORKSPACES_PATH=./dev/runtime/workspaces

# Local image tag built by `docker build` in dev mode.
DIND_IMAGE_NAME=vbr-dind:local

# Docker volume for inner Docker data (dev).
DIND_DOCKER_VOLUME_NAME=vbr-dind-docker-data

# __PROD__
# Registry image reference (baked by CI: DOCKERHUB_NAMESPACE/vibeboyrunner:<version>).
DIND_IMAGE_REF=vibeboyrunner/vibeboyrunner:VERSION

# URL of this setup script on gh-pages (baked by CI).
VBR_RELEASE_SETUP_URL=https://vibeboyrunner.github.io/vibeboyrunner/setups/VERSION/setup.sh

# Prod container name (overrides shared default).
DIND_CONTAINER_NAME=vibeboyrunner

# Named volumes for persistent state (prod).
DIND_HOME_VOLUME_NAME=vibeboyrunner-home
DIND_WORKSPACES_VOLUME_NAME=vibeboyrunner-workspaces
DIND_DOCKER_VOLUME_NAME=vibeboyrunner-docker-data
